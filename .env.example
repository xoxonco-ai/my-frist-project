# === 複製這個檔案為 .env，填入你自己的金鑰 ===
# .env 已被 .gitignore 忽略，不會上傳，安全。

# --- 模組 3：一稿多平台改寫（Anthropic）---
ANTHROPIC_API_KEY=sk-ant-...

# --- 模組 2：Meta（IG / FB / Threads）---
# 到 https://developers.facebook.com 建立 App 後取得
META_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
FB_PAGE_ID=

# Threads 官方 API：https://developers.facebook.com/docs/threads
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# --- 模組 2：抖音開放平台 ---
# https://developer.open-douyin.com
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_ACCESS_TOKEN=

# --- 小紅書 ---
# 小紅書無公開資料 API；數據請至「蒲公英」或「專業號後台」查看。
